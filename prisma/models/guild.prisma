model GuildSettings {
  id                         Int      @id @default(autoincrement())
  guildId                    String   @unique
  // Voice patrol settings
  patrolChannelCategoryId    String?
  // Patrol promotion settings
  promotionChannelId         String? // Channel ID for promotion notifications
  toPromoteChannelId         String? // Channel ID for posting users who were promoted
  promotionRules             Json? // Array of { currentRankRoleId, nextRankRoleId, requiredHours, cooldownHours?, declinedCooldownHours? } for rank-based rules
  // Attendance settings
  hostAttendanceRoleIds      Json? // Array of role IDs for host attendance
  jrHostRoleIds              Json? // Array of role IDs for Jr. event hosts
  enrolledChannels           Json? // Array of channel IDs for attendance squads
  aocChannelId               String? // Channel ID for AOC (Attendance Operations Center) squad
  aocVoiceChannelId          String? // AoC voice channel — panel posts to its linked in-voice text chat
  aocPanelMessageId          String? // Current AoC panel message ID (reposted to stay at bottom)
  emtVoiceChannelId          String? // EMT voice channel — same phantom-compiler panel as AoC
  emtPanelMessageId          String? // Current EMT panel message ID (reposted to stay at bottom)
  instigationLogChannelId    String? // Channel ID for instigation logs (reminder channel for AOC leads)
  // Shield member settings
  shieldMemberRoleIds        Json? // Array of role IDs for shield members
  // Staff settings
  staffRoleIds               Json? // Array of role IDs for staff
  trainerRoleIds             Json? // Array of role IDs for trainers
  devGuardRoleIds            Json? // Array of role IDs for dev guards
  // Whitelist settings
  whitelistLogChannelId      String? // Channel ID for whitelist verification and modification logs
  whitelistGitHubToken       String? // GitHub token for whitelist repository updates
  whitelistGitHubOwner       String? // GitHub repository owner
  whitelistGitHubRepo        String? // GitHub repository name
  whitelistGitHubBranch      String? // GitHub repository branch (default: main)
  whitelistGitHubEncodedPath String? // Path for encoded whitelist file (default: whitelist.encoded.txt)
  whitelistGitHubDecodedPath String? // Path for decoded whitelist file (default: whitelist.txt)
  whitelistXorKey            String? // XOR key for whitelist encoding
  // Patrol settings
  patrolLogChannelId         String? // Channel ID for patrol hours and command usage logs
  patrolTopChannelId         String? // Channel ID for weekly patrol top posts
  hostWeeklyEventReminderChannelId String? // Channel ID for weekly Thursday host / Jr. host event reminder (Europe/Amsterdam)
  // Event scheduling settings
  eventPlanningChannelId     String? // Channel ID where pending event approval embeds are posted
  eventScheduleChannelId     String? // Legacy fallback for on-duty schedule channel
  eventOnDutyScheduleChannelId   String? // Channel for exported on-duty weekly schedule
  eventOffDutyScheduleChannelId  String? // Channel for exported off-duty weekly schedule
  eventOnDutyPingRoleId      String? // Role pinged at top of on-duty schedule post
  eventOffDutyPingRoleIds    Json?   // Role IDs pinged at top of off-duty schedule post
  eventPatrolEmojiName       String? // Custom emoji name for patrol events (e.g. EventHosts)
  eventPatrolEmojiId         String? // Custom emoji ID for patrol events
  eventDefaultLocation       String? // Default location for exported external Discord scheduled events
  eventDefaultDurationMinutes Int? // Default event duration in minutes (null treated as 120 in code)
  // VRChat instance settings
  avatarWorldId              String? // VRChat world ID for avatar world invites (e.g., wrld_xxx)
  // VRChat group settings
  vrcGroupId                 String? // VRChat group ID for group invites and role sync (e.g., grp_xxx)
  botPromotionLogsChannelId  String? // Channel ID for logging VRChat group promotions/demotions
  // LOA settings
  loaRoleId                  String? // Discord role ID for LOA
  loaNotificationChannelId  String? // Channel ID for LOA patrol notifications
  leaveOfAbsenceCooldownDays Int?    @default(14) // Cooldown period in days after ending LOA early
  minimumRequestTimeDays     Int?    @default(30) // Minimum LOA duration in days (default: 1 month)
  // Role tracking settings
  roleTrackingConfig         Json? // Map of role IDs to role tracking configurations
  roleTrackingStaffChannelId String? // Channel ID for role tracking staff notifications
  roleTrackingAdvisorRoleId  String? // Discord role ID excluded from all role tracking checks
  roleTrackingInitializedAt  DateTime? // Timestamp when role tracking was first enabled for this guild
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
}
