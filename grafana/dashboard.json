            "editorMode": "code",
            "format": "time_series",
            "rawQuery": true,
            "rawSql": "SELECT\n  UNIX_TIMESTAMP(STR_TO_DATE(CONCAT(year, '-', LPAD(month, 2, '0'), '-01'), '%Y-%m-%d')) as time_sec,\n  CAST(AVG(user_total) AS DECIMAL(20,2)) / 3600000 as value\nFROM (\n  SELECT year, month, userId, SUM(totalMs) as user_total\n  FROM VoicePatrolMonthlyTime\n  GROUP BY userId, year, month\n) as user_totals\nWHERE STR_TO_DATE(CONCAT(year, '-', LPAD(month, 2, '0'), '-01'), '%Y-%m-%d') >= FROM_UNIXTIME($__unixEpochFrom())\n  AND STR_TO_DATE(CONCAT(year, '-', LPAD(month, 2, '0'), '-01'), '%Y-%m-%d') <= FROM_UNIXTIME($__unixEpochTo())\nGROUP BY year, month\nORDER BY time_sec",
            "refId": "A"
          }
        ],
        "title": "Average Hours Per User Per Month",
