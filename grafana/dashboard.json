            "editorMode": "code",
            "format": "time_series",
            "rawQuery": true,
            "rawSql": "SELECT\n  UNIX_TIMESTAMP(STR_TO_DATE(CONCAT(year, '-', LPAD(month, 2, '0'), '-01'), '%Y-%m-%d')) as time_sec,\n  CAST(SUM(totalMs) AS DECIMAL(20,2)) / 3600000 as value\nFROM VoicePatrolMonthlyTime\nWHERE STR_TO_DATE(CONCAT(year, '-', LPAD(month, 2, '0'), '-01'), '%Y-%m-%d') >= FROM_UNIXTIME($__unixEpochFrom())\n  AND STR_TO_DATE(CONCAT(year, '-', LPAD(month, 2, '0'), '-01'), '%Y-%m-%d') <= FROM_UNIXTIME($__unixEpochTo())\nGROUP BY year, month\nORDER BY time_sec",
            "refId": "A"
          }
        ],
        "title": "Monthly Patrol Hours Trend",
        "type": "timeseries"
